# ══════════════════════════════════════════════════════════════
#  MEDIX AI — Variables de Entorno
#  Copia este archivo como .env y llena los valores reales
# ══════════════════════════════════════════════════════════════

# ── Base de Datos ──────────────────────────────────────────────
POSTGRES_PASSWORD=MedixSecurePass2024!
DATABASE_URL=postgresql+asyncpg://medix_user:MedixSecurePass2024!@db:5432/medix_db

# ── Redis ──────────────────────────────────────────────────────
REDIS_PASSWORD=RedisSecurePass2024!
REDIS_URL=redis://:RedisSecurePass2024!@redis:6379/0

# ── JWT (genera con: openssl rand -hex 32) ─────────────────────
JWT_SECRET_KEY=REEMPLAZA_CON_32_CHARS_ALEATORIOS_openssl_rand_hex_32
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# ── Anthropic Claude ───────────────────────────────────────────
# Obtén tu API Key en: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-XXXXXXXXXXXXXXXXXXXX

# ── AWS S3 (para MedScan — imágenes médicas) ──────────────────
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_REGION=us-east-1
S3_BUCKET_MEDSCAN=medix-scans-prod

# ── Stripe (para suscripciones) ────────────────────────────────
STRIPE_SECRET_KEY=sk_test_XXXXXXXXXXXXXXXXXXXX
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXXXXXX
STRIPE_PRICE_PRO=price_XXXXXXXXXXXXXXXXXXXX
STRIPE_PRICE_CLINICAL=price_XXXXXXXXXXXXXXXXXXXX

# ── Entorno ────────────────────────────────────────────────────
ENVIRONMENT=development
# Cambiar a "production" al desplegar en Railway/AWS

# ── Sprint 3 — Firebase FCM ────────────────────────────────────
FIREBASE_PROJECT_ID=medix-ai-hn
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"medix-ai-hn",...}
# Descarga el JSON completo desde: Firebase Console → Configuración → Cuentas de servicio
# Pega el contenido completo del JSON como string (en una sola línea) aquí

# ── PayPal (para Honduras — reemplaza Stripe) ──────────────────
# Obtén las credenciales en: developer.paypal.com → My Apps & Credentials
PAYPAL_CLIENT_ID=AX...tu-client-id...
PAYPAL_CLIENT_SECRET=EL...tu-client-secret...
PAYPAL_WEBHOOK_ID=WH-...tu-webhook-id...
PAYPAL_MODE=sandbox
# Cambia a "live" cuando actives pagos reales

# ── Beta Mode ──────────────────────────────────────────────────
BETA_MODE=true
# true = todos los beta users reciben Pro gratis (deploy inicial)
# false = pagos reales con PayPal activados
BETA_USERS_LIMIT=100
